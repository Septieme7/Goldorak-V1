# Backend Environment Variables - OAuth2

# Application
NODE_ENV=development
PORT=8800
APP_NAME=Goldorak API
APP_VERSION=1.0.0

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=goldorak_db

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
CORS_METHODS=GET,POST,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# JWT Secret (CHANGEZ-MOI EN PRODUCTION)
JWT_SECRET=votre_secret_jwt_tres_securise_changez_moi_en_production
JWT_EXPIRES_IN=7d

# Session Secret (CHANGEZ-MOI EN PRODUCTION)
SESSION_SECRET=votre_secret_session_tres_securise_changez_moi_en_production

# Google OAuth2
# Obtenez vos clés sur: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=votre_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=votre_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8800/api/v1/auth/google/callback

# GitHub OAuth2
# Obtenez vos clés sur: https://github.com/settings/developers
GITHUB_CLIENT_ID=votre_github_client_id
GITHUB_CLIENT_SECRET=votre_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:8800/api/v1/auth/github/callback

# Logging
LOG_LEVEL=info