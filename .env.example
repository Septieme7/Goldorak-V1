# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=goldorak_db
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password

# Backend
PORT=8800
NODE_ENV=production
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Sessions & JWT
SESSION_SECRET=un_secret_long_et_aleatoire_pour_les_sessions
JWT_SECRET=un_autre_secret_pour_jwt

# OAuth Google (optionnel)
GOOGLE_CLIENT_ID=votre_client_id_google
GOOGLE_CLIENT_SECRET=votre_secret_google
GOOGLE_CALLBACK_URL=http://localhost:8800/api/v1/auth/google/callback

# OAuth GitHub (optionnel)
GITHUB_CLIENT_ID=votre_client_id_github
GITHUB_CLIENT_SECRET=votre_secret_github
GITHUB_CALLBACK_URL=http://localhost:8800/api/v1/auth/github/callback